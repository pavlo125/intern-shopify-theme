<!-- 1. CSS Styles -->
<style>
  .drawer-overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease;
  }
  .drawer-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .drawer-panel {
    position: fixed;
    top: 0; right: 0; width: 100%; max-width: 400px; height: 100vh;
    background: #fff;
    z-index: 9999;
    transform: translateX(100%); /* Сховано за правим краєм */
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -5px 0 15px rgba(0,0,0,0.1);
  }
  .drawer-panel.is-active {
    transform: translateX(0); /* Виїжджає на екран */
  }

  .drawer-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px; border-bottom: 1px solid #eee;
  }
  .drawer-close {
    background: none; border: none; font-size: 1.5rem; cursor: pointer;
  }
  .drawer-body {
    flex: 1; overflow-y: auto; padding: 20px;
  }
  .drawer-footer {
    padding: 20px; border-top: 1px solid #eee; background: #fafafa;
  }
  
  /* Стилі для товарів */
  .drawer-item { display: flex; gap: 15px; margin-bottom: 20px; }
  .drawer-item img { width: 80px; height: 80px; object-fit: cover; border-radius: 4px; }
  .drawer-item-details h4 { margin: 0 0 5px 0; font-size: 1rem; }
  .drawer-checkout-btn {
    display: block; width: 100%; padding: 15px; background: #000;
    color: #fff; text-align: center; text-decoration: none; font-weight: bold; border-radius: 4px;
  }
</style>

<!-- 2. Web Component HTML -->
<custom-cart-drawer id="CartDrawerElement">
  
  <!-- Затемнення фону -->
  <div class="drawer-overlay" id="DrawerOverlay"></div>
  
  <!-- Сама панель, що виїжджає -->
  <div class="drawer-panel" id="DrawerPanel">
    
    <!-- Цей внутрішній div ми будемо ПОВНІСТЮ замінювати через Section Rendering API -->
    <div id="DrawerInnerContent">
      <div class="drawer-header">
        <h2 style="margin: 0;">Your Cart ({{ cart.item_count }})</h2>
        <button class="drawer-close" id="DrawerClose">&times;</button>
      </div>

      <div class="drawer-body">
        {% if cart.item_count == 0 %}
          <p>Your cart is empty.</p>
        {% else %}
          {% for item in cart.items %}
            <div class="drawer-item">
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}">
              <div class="drawer-item-details">
                <h4>{{ item.product.title }}</h4>
                {% unless item.product.has_only_default_variant %}
                  <p style="margin: 0; font-size: 0.9rem; color: #666;">{{ item.variant.title }}</p>
                {% endunless %}
                <p style="margin: 5px 0 0 0; font-weight: bold;">{{ item.final_line_price | money }}</p>
                <p style="margin: 5px 0 0 0; font-size: 0.9rem;">Qty: {{ item.quantity }}</p>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <div class="drawer-footer">
        <div style="display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 1.2rem; font-weight: bold;">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <a href="/checkout" class="drawer-checkout-btn">Go to Checkout</a>
      </div>
    </div>
    <!-- Кінець DrawerInnerContent -->

  </div>
</custom-cart-drawer>

<!-- 3. JavaScript -->
<script>
  class CustomCartDrawer extends HTMLElement {
    constructor() {
      super();
      this.overlay = this.querySelector('#DrawerOverlay');
      this.panel = this.querySelector('#DrawerPanel');
      
      // Біндимо методи для збереження контексту
      this.open = this.open.bind(this);
      this.close = this.close.bind(this);
      this.updateMarkup = this.updateMarkup.bind(this);
    }

    connectedCallback() {
      // Вішаємо слухачів на закриття (клік по хрестику або темному фону)
      this.addEventListener('click', (e) => {
        if (e.target.id === 'DrawerOverlay' || e.target.id === 'DrawerClose') {
          this.close();
        }
      });
    }

    open() {
      this.overlay.classList.add('is-active');
      this.panel.classList.add('is-active');
      document.body.style.overflow = 'hidden'; // Блокуємо скрол сайту
    }

    close() {
      this.overlay.classList.remove('is-active');
      this.panel.classList.remove('is-active');
      document.body.style.overflow = 'auto';
    }

    // === ТА САМА МАГІЯ SECTION RENDERING API ===
    updateMarkup() {
      // 1. Формуємо запит. Ми кажемо Shopify: "Відрендери для нас секцію з ID 'custom-cart-drawer'"
      // ID секції - це просто назва файлу секції без .liquid
      const sectionId = 'custom-cart-drawer';
      
      fetch(`/?sections=${sectionId}`)
        .then(response => response.json())
        .then(data => {
          // Shopify повертає JSON, де ключ - це ID секції, а значення - готовий HTML
          const rawHtml = data[sectionId]; 

          // 2. Перетворюємо текст на віртуальний HTML-документ
          const htmlDocument = new DOMParser().parseFromString(rawHtml, 'text/html');

          // 3. Беремо свіжий блок DrawerInnerContent з віртуального документа...
          const freshInnerContent = htmlDocument.querySelector('#DrawerInnerContent').innerHTML;

          // 4. ...і вставляємо його в наш реальний кошик на сторінці!
          this.querySelector('#DrawerInnerContent').innerHTML = freshInnerContent;
          
          // 5. Відкриваємо кошик, щоб показати оновлені дані
          this.open();
        })
        .catch(error => console.error('Error updating cart drawer:', error));
    }
  }

  customElements.define('custom-cart-drawer', CustomCartDrawer);
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [],
  "presets": [
    {
      "name": "Custom: Cart Drawer"
    }
  ]
}
{% endschema %}