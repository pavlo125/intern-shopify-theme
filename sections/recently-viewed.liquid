<!-- Контейнер спочатку схований (display: none). Він з'явиться тільки якщо є історія -->
<div class="recently-viewed-section" style="max-width: 1200px; margin: 50px auto; padding: 0 20px; font-family: sans-serif; display: none;" id="recently-viewed-wrapper">
  
  {% if section.settings.title != blank %}
    <h2 style="text-align: center; margin-bottom: 30px;">{{ section.settings.title }}</h2>
  {% endif %}

  <div id="recently-viewed-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const STORAGE_KEY = 'shopify_recently_viewed';
    const MAX_ITEMS = 4; 

    
    {% if template contains 'product' %}
      
      const currentProduct = {
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        url: {{ product.url | json }},
        image: {{ product.featured_image | image_url: width: 400 | json }},
        price: '{{ product.price | money }}'
      };

      
      let recentProducts = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');

      // 1. Видаляємо поточний товар зі списку (якщо він там вже був), щоб не було дублікатів
      recentProducts = recentProducts.filter(item => item.handle !== currentProduct.handle);

      recentProducts.unshift(currentProduct);

      if (recentProducts.length > MAX_ITEMS) {
        recentProducts.pop();
      }

      localStorage.setItem(STORAGE_KEY, JSON.stringify(recentProducts));
    {% endif %}


    const grid = document.getElementById('recently-viewed-grid');
    const wrapper = document.getElementById('recently-viewed-wrapper');
    
    // Дістаємо історію з пам'яті
    let storedProducts = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');

    
    {% if template contains 'product' %}
      const currentHandle = {{ product.handle | json }};
      storedProducts = storedProducts.filter(item => item.handle !== currentHandle);
    {% endif %}

    if (storedProducts.length > 0) {
      wrapper.style.display = 'block'; 

      let html = ''; 

      
      storedProducts.forEach(product => {
        html += `
          <div style="border: 1px solid #eee; border-radius: 8px; padding: 15px; text-align: center; transition: box-shadow 0.3s;">
            <a href="${product.url}" style="text-decoration: none; color: inherit;">
              <img src="${product.image}" alt="${product.title}" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px; margin-bottom: 15px;">
              <h4 style="font-size: 1rem; margin: 0 0 10px 0;">${product.title}</h4>
              <div style="font-weight: bold; color: #333;">${product.price}</div>
            </a>
          </div>
        `;
      });

      
      grid.innerHTML = html;
    }
  });
</script>

{% schema %}
{
  "name": "Recently viewed",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title of section",
      "default": "You recently viewed"
    }
  ],
  "presets": [
    {
      "name": "Reacently viewed"
    }
  ]
}
{% endschema %}