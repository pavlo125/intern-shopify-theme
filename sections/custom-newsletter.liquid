<div style="background-color: {{ section.settings.bg_color }}; padding: 60px 20px; text-align: center; font-family: sans-serif;">
  <div style="max-width: 600px; margin: 0 auto;">
    
    <h2 style="font-size: 2rem; color: #333; margin-bottom: 10px;">
      {{ section.settings.heading }}
    </h2>
    <p style="color: #666; margin-bottom: 30px; font-size: 1.1rem;">
      {{ section.settings.subheading }}
    </p>

    {% form 'customer', id: 'newsletter-form' %}
      
    
      <input type="hidden" name="contact[tags]" value="newsletter">

      {% if form.posted_successfully? %}
        <div style="background-color: #d4edda; color: #155724; padding: 15px; border-radius: 5px; margin-bottom: 20px; font-weight: bold;">
          Thank you for subscribing! Please check your email.
        </div>
      {% endif %}

      {% if form.errors %}
        <div style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 5px; margin-bottom: 20px; font-weight: bold;">
          {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
        </div>
      {% endif %}

      <div style="display: flex; gap: 10px; justify-content: center; max-width: 500px; margin: 0 auto;">
        
        <input 
          type="email" 
          name="contact[email]" 
          id="NewsletterEmail" 
          value="{% if customer %}{{ customer.email }}{% endif %}" 
          placeholder="Email address" 
          required 
          style="flex: 1; padding: 12px 15px; border: 1px solid #ccc; border-radius: 5px; font-size: 1rem; outline: none;"
        >
        
        <button 
          type="submit" 
          style="padding: 12px 25px; background-color: #000; color: #fff; border: none; border-radius: 5px; font-size: 1rem; cursor: pointer; font-weight: bold; transition: background 0.2s;"
        >
          Subscribe
        </button>

      </div>
    {% endform %}

  </div>
</div>

    {% schema %}
{
  "name": "Newsletter Signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get exclusive discounts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to our newsletter and get 10% off your first order."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f9f9f9"
    }
  ],
  "presets": [
    {
      "name": "Custom: Newsletter Signup"
    }
  ]
}
{% endschema %}